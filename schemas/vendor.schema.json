{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GRCEngClub/claude-grc-engineering/schemas/vendor.schema.json",
  "title": "GRC Vendor Record",
  "description": "Canonical contract for vendor inventory and review records stored in grc-data.",
  "type": "object",
  "required": [
    "schema_version",
    "vendor_id",
    "name",
    "tier",
    "status"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "vendor_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "name": {
      "type": "string"
    },
    "tier": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "out-of-scope"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "prospect",
        "active",
        "paused",
        "offboarded"
      ]
    },
    "owner": {
      "anyOf": [
        {
          "$ref": "#/$defs/person_ref"
        },
        {
          "type": "null"
        }
      ]
    },
    "contacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/contact_ref"
      }
    },
    "services": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_review_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "next_review_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "linked_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "person_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "team": {
          "type": "string"
        }
      },
      "anyOf": [
        {
          "required": [
            "name"
          ]
        },
        {
          "required": [
            "team"
          ]
        },
        {
          "required": [
            "email"
          ]
        }
      ]
    },
    "contact_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ]
    }
  }
}
